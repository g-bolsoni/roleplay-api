    "eslint": "^8.40.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-adonis": "^2.1.1",
    "eslint-plugin-prettier": "^5.5.4",
    "execa": "^5.1.1",
    "get-port": "^5.1.1",
    "japa": "^4.0.0",
    "pino-pretty": "^9.1.1",
    "prettier": "^3.7.4",
    "sqlite3": "^5.1.7",
    "supertest": "^7.1.4",
    "typescript": "^4.2.4",
    "youch": "^3.3.4",
    "youch-terminal": "^2.2.3"
  },
  "dependencies": {
    "@adonisjs/core": "^5.9.0",
